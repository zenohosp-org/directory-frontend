# API Configuration
# In production, set this to the API server URL (e.g., https://api-directory.zenohosp.com)
# In development, the vite dev server proxies /api and /oauth2 requests to this URL
VITE_API_BASE_URL=https://api-directory.zenohosp.com

# Cross-app logout endpoints (set in Vercel env vars for production)
VITE_ASSET_API_URL=https://api-asset.zenohosp.com
VITE_INVENTORY_API_URL=https://api-inventory.zenohosp.com
VITE_HMS_API_URL=https://api-hms.zenohosp.com
